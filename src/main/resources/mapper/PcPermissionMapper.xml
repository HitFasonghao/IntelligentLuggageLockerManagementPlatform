<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.example.auth.mapper.PcPermissionMapper">
    <!-- 定义结果映射（可选，但推荐，确保字段映射准确） -->
    <resultMap id="PcPermissionResultMap" type="org.example.auth.po.PcPermissionPO">
        <id column="permission_id" property="id"/>
        <result column="name" property="name"/>
        <result column="code" property="code"/>
        <result column="type" property="type"/>
        <result column="parent_id" property="parentId"/>
        <result column="path" property="path"/>
        <result column="redirect" property="redirect"/>
        <result column="icon" property="icon"/>
        <result column="component" property="component"/>
        <result column="layout" property="layout"/>
        <result column="keep_alive" property="keepAlive"/>
        <result column="method" property="method"/>
        <result column="description" property="description"/>
        <result column="show_status" property="showStatus"/>
        <result column="enable_status" property="enableStatus"/>
        <result column="sort" property="sort"/>
        <result column="created_time" property="createdTime"/>
        <result column="updated_time" property="updatedTime"/>
    </resultMap>

    <!-- queryByRoleId 方法：联表查询角色权限 -->
    <select id="queryByRoleId" parameterType="java.lang.Integer" resultMap="PcPermissionResultMap">
        SELECT p.permission_id,
               p.name,
               p.code,
               p.type,
               p.parent_id,
               p.path,
               p.redirect,
               p.icon,
               p.component,
               p.layout,
               p.keep_alive,
               p.method,
               p.description,
               p.show_status,
               p.enable_status,
               p.sort,
               p.created_time,
               p.updated_time
        FROM pc_permission p
        INNER JOIN pc_role_permission rp ON p.permission_id = rp.permission_id
        WHERE rp.role_id = #{roleId}
        ORDER BY p.sort ASC
    </select>

</mapper>